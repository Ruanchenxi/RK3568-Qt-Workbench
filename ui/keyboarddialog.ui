<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>KeyboardDialog</class>
 <widget class="QDialog" name="KeyboardDialog">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>700</width>
    <height>380</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>虚拟键盘</string>
  </property>
  <property name="modal">
   <bool>true</bool>
  </property>
  <property name="styleSheet">
   <string notr="true">
    /* 对话框整体样式 */
    QDialog#KeyboardDialog {
      background-color: #2C3E50;
      border-radius: 12px;
    }
    
    /* 输入框样式 */
    QLineEdit#inputDisplay {
      background-color: #34495E;
      border: 2px solid #2E7D32;
      border-radius: 8px;
      padding: 12px 16px;
      font-size: 24px;
      color: #FFFFFF;
      font-family: "Consolas", "Monaco", monospace;
    }
    QLineEdit#inputDisplay:focus {
      border-color: #4CAF50;
    }
    
    /* 按键通用样式 */
    QPushButton {
      background-color: #465A6E;
      color: #FFFFFF;
      border: none;
      border-radius: 8px;
      font-size: 18px;
      font-weight: bold;
      min-width: 50px;
      min-height: 50px;
    }
    QPushButton:hover {
      background-color: #5D7A93;
    }
    QPushButton:pressed {
      background-color: #2E7D32;
    }
    
    /* 特殊功能键样式 */
    QPushButton#btnBackspace, QPushButton#btnClear {
      background-color: #C0392B;
    }
    QPushButton#btnBackspace:hover, QPushButton#btnClear:hover {
      background-color: #E74C3C;
    }
    
    QPushButton#btnShift, QPushButton#btnCaps {
      background-color: #2980B9;
    }
    QPushButton#btnShift:hover, QPushButton#btnCaps:hover {
      background-color: #3498DB;
    }
    QPushButton#btnShift:checked, QPushButton#btnCaps:checked {
      background-color: #2E7D32;
    }
    
    QPushButton#btnSpace {
      min-width: 300px;
    }
    
    QPushButton#btnOK {
      background-color: #2E7D32;
      min-width: 100px;
    }
    QPushButton#btnOK:hover {
      background-color: #4CAF50;
    }
    
    QPushButton#btnCancel {
      background-color: #7F8C8D;
      min-width: 80px;
    }
    QPushButton#btnCancel:hover {
      background-color: #95A5A6;
    }
    
    /* 数字键样式 */
    QPushButton[objectName^="btnNum"] {
      background-color: #5D4E6D;
    }
    QPushButton[objectName^="btnNum"]:hover {
      background-color: #7B6B8D;
    }
   </string>
  </property>
  
  <layout class="QVBoxLayout" name="mainLayout">
   <property name="spacing">
    <number>12</number>
   </property>
   <property name="margin">
    <number>20</number>
   </property>
   
