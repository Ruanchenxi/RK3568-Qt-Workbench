  <property name="styleSheet">
   <string notr="true">
/* ========== 系统设置页面样式 ========== */
#SystemPage {
    background-color: transparent;
}

/* 页面标题 */
#pageTitle {
    color: #2C3E50;
    font-size: 24px;
    font-weight: normal;
}

/* 标签页切换按钮 - 基础样式 */
#tabBasic, #tabAdvanced, #tabUserIdentity {
    background-color: transparent;
    color: #5D6B7A;
    font-size: 13px;
    border: none;
    border-radius: 6px;
    padding: 8px 16px;
    min-width: 80px;
}

#tabBasic:hover, #tabAdvanced:hover, #tabUserIdentity:hover {
    background-color: #E8F5E9;
}

#tabBasic:pressed, #tabAdvanced:pressed, #tabUserIdentity:pressed {
    background-color: #C8E6C9;
}

#tabBasic:checked, #tabAdvanced:checked, #tabUserIdentity:checked {
    background-color: #2E7D32;
    color: #FFFFFF;
}

/* 表单面板 */
#sysFormPanel {
    background-color: #FFFFFF;
    border: 1px solid #E8E4DE;
    border-radius: 12px;
}

#contentStack {
    background: transparent;
    border: none;
}

#basicPage, #advancedPage {
    background: transparent;
}

#basicIntroCard {
    background-color: #F8FAFB;
    border: 1px solid #E8E4DE;
    border-radius: 12px;
}

#basicHintLabel {
    color: #5D6B7A;
    font-size: 13px;
    background: transparent;
    border: none;
}

#advancedIntroCard {
    background-color: #F8FAFB;
    border: 1px solid #E8E4DE;
    border-radius: 12px;
}

#advancedHintLabel {
    color: #5D6B7A;
    font-size: 13px;
    background: transparent;
    border: none;
}

#advancedContentHost {
    background-color: #FFFFFF;
    border: 1px dashed #C8D1D9;
    border-radius: 12px;
}

/* 表单标题 */
#formTitle {
    color: #2C3E50;
    font-size: 16px;
    border: none;
    background: transparent;
}

/* 分区标题 - 加粗醒目 */
#sectionTitle1, .sectionTitle {
    color: #2C3E50;
    font-size: 14px;
    font-weight: bold;
    background: transparent;
    border: none;
    padding: 8px 0;
}

/* 字段标签 - 无边框纯文字 */
#field1Label, #field2Label, #field3Label, #field4Label, 
#field5Label, #field6Label, #field7Label, #field8Label {
    color: #5D6B7A;
    font-size: 13px;
    background: transparent;
    border: none;
    padding: 0;
}

/* 输入框 */
QLineEdit {
    background-color: #F5F3EF;
    border: 1px solid #E8E4DE;
    border-radius: 8px;
    padding: 12px 16px;
    font-size: 14px;
    color: #2C3E50;
    min-height: 20px;
}

/* 下拉框 */
QComboBox {
    background-color: #F5F3EF;
    border: 1px solid #E8E4DE;
    border-radius: 8px;
    padding: 12px 16px;
    font-size: 14px;
    color: #2C3E50;
    min-width: 140px;
    min-height: 20px;
}

QLineEdit:focus, QComboBox:focus {
    border-color: #2E7D32;
}

QComboBox::drop-down {
    border: none;
    width: 30px;
}

QComboBox::down-arrow {
    image: none;
}

QComboBox QAbstractItemView {
    background-color: #FFFFFF;
    border: 1px solid #E8E4DE;
    selection-background-color: #E8F5E9;
}

/* 刷新按钮 - 点击效果 */
#refreshBtn {
    background-color: #FFFFFF;
    color: #5D6B7A;
    font-size: 13px;
    border: 1px solid #E0E0E0;
    border-radius: 6px;
    padding: 8px 16px;
    min-width: 60px;
}

#refreshBtn:pressed {
    background-color: #BDBDBD;
    border-color: #888888;
    color: #333333;
}

/* 保存按钮 - 点击效果 */
#saveBtn {
    background-color: #2E7D32;
    color: #FFFFFF;
    font-size: 13px;
    border: none;
    border-radius: 6px;
    padding: 8px 16px;
    min-width: 80px;
}

#saveBtn:pressed {
    background-color: #145A14;
}

/* 分隔线 */
.divider {
    background-color: #E8E4DE;
}
