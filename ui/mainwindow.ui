  <property name="styleSheet">
   <string notr="true">
/* ========== 全局样式 ========== */
QMainWindow {
    background-color: #F5F3EF;
}

/* ========== 顶部导航栏样式 ========== */
#headerWidget {
    background-color: #FFFFFF;
    border-bottom: 1px solid #E8E4DE;
}

/* Logo区域标题 */
#systemTitle {
    color: #2C3E50;
    font-size: 18px;
    font-weight: normal;
}

/* 导航按钮通用样式 */
#btnWorkbench, #btnKeys, #btnSystem, #btnService, #btnKeyboard {
    background-color: transparent;
    color: #5D6B7A;
    font-size: 14px;
    border: none;
    border-radius: 6px;
    padding: 10px 20px;
}

#btnWorkbench:hover, #btnKeys:hover, #btnSystem:hover, #btnService:hover, #btnKeyboard:hover {
    background-color: #E8E4DE;
}

#btnWorkbench:checked, #btnKeys:checked, #btnSystem:checked, #btnService:checked, #btnKeyboard:checked {
    background-color: #2E7D32;
    color: #FFFFFF;
}

/* 用户信息 */
#userNameLabel {
    color: #2C3E50;
    font-size: 14px;
}

/* 退出按钮 */
#logoutBtn {
    background-color: transparent;
    color: #5D6B7A;
    font-size: 13px;
    border: 1px solid #E0E0E0;
    border-radius: 6px;
    padding: 8px 16px;
}

#logoutBtn:hover {
    background-color: #F5F5F5;
}

/* ========== 底部状态栏样式 ========== */
#footerWidget {
    background-color: #FFFFFF;
    border-top: 1px solid #E8E4DE;
}

#companyLabel {
    color: #9E9E9E;
    font-size: 12px;
}

#timeLabel {
    color: #5D6B7A;
    font-size: 12px;
}

#userInfoLabel, #roleLabel {
    color: #5D6B7A;
    font-size: 12px;
}

#cardStatusLabel, #fingerStatusLabel {
    color: #5D6B7A;
    font-size: 12px;
}

/* ========== 内容区域样式 ========== */
#contentStackedWidget {
    background-color: transparent;
}
