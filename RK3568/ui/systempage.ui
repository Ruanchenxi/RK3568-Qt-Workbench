  <property name="styleSheet">
   <string notr="true">
/* ========== 系统设置页面样式 ========== */
#SystemPage {
    background-color: transparent;
}

/* 页面标题 */
#pageTitle {
    color: #2C3E50;
    font-size: 24px;
    font-weight: normal;
}

/* 标签页切换按钮 - 基础样式 */
#tabBasic, #tabAdvanced {
    background-color: transparent;
    color: #5D6B7A;
    font-size: 16px;
    border: none;
    border-radius: 8px;
    padding: 12px 22px;
    min-width: 120px;
}

#tabBasic:hover, #tabAdvanced:hover, #tabUserIdentity:hover {
    background-color: #E8F5E9;
}

#tabBasic:pressed, #tabAdvanced:pressed, #tabUserIdentity:pressed {
    background-color: #C8E6C9;
}

#tabBasic:checked, #tabAdvanced:checked, #tabUserIdentity:checked {
    background-color: #2E7D32;
    color: #FFFFFF;
}

#sysTabs {
    background-color: #FFFFFF;
    border: 1px solid #E8E4DE;
    border-radius: 8px;
    padding: 4px;
}

/* 表单面板 */
#sysFormPanel {
    background-color: #FFFFFF;
    border: 1px solid #E8E4DE;
    border-radius: 12px;
}

#formHeader {
    border-bottom: 1px solid #E8E4DE;
    background: transparent;
}

#contentStack {
    background: transparent;
    border: none;
}

#basicPage, #advancedPage {
    background: transparent;
}

#basicIntroCard {
    background-color: #F8FAFB;
    border: 1px solid #E8E4DE;
    border-radius: 12px;
}

#basicProfileCard, #basicSerialCard {
    background-color: transparent;
    border: none;
    border-radius: 0;
}

#basicHintLabel {
    color: #5D6B7A;
    font-size: 13px;
    background: transparent;
    border: none;
}

#advancedIntroCard {
    background-color: #F8FAFB;
    border: 1px solid #E8E4DE;
    border-radius: 12px;
}

#advancedHintLabel {
    color: #5D6B7A;
    font-size: 13px;
    background: transparent;
    border: none;
}

#advancedContentHost {
    background-color: #FFFFFF;
    border: none;
    border-radius: 12px;
}

#advancedActionCard, #advancedTableCard {
    background: transparent;
    border: none;
}

#advancedActionHintLabel {
    color: #FF6B35;
    font-size: 13px;
    background: transparent;
    border: none;
}

#formScrollArea {
    border: none;
    background: transparent;
}

#collectFingerprintBtn {
    background-color: #FFFFFF;
    color: #2E7D32;
    font-size: 16px;
    border: 1px solid #2E7D32;
    border-radius: 8px;
    padding: 12px 22px;
    min-width: 132px;
}

#collectFingerprintBtn:hover {
    background-color: #E8F5E9;
}

#collectFingerprintBtn:pressed {
    background-color: #C8E6C9;
}

#collectFingerprintBtn:disabled {
    background-color: #FAFAFA;
    color: #B9C2BB;
    border: 1px solid #E8E4DE;
}

#deleteCardBtn {
    background-color: #FFFFFF;
    color: #C62828;
    font-size: 16px;
    border: 1px solid #E0B6B6;
    border-radius: 8px;
    padding: 12px 22px;
    min-width: 132px;
}

#deleteCardBtn:hover {
    background-color: #FFF2F2;
}

#deleteCardBtn:pressed {
    background-color: #F6DCDC;
}

#deleteCardBtn:disabled {
    background-color: #FAFAFA;
    color: #CCB7B7;
    border-color: #E8E4DE;
}

#deleteFingerprintBtn {
    background-color: #FFFFFF;
    color: #C62828;
    font-size: 16px;
    border: 1px solid #E0B6B6;
    border-radius: 8px;
    padding: 12px 22px;
    min-width: 132px;
}

#deleteFingerprintBtn:hover {
    background-color: #FFF2F2;
}

#deleteFingerprintBtn:pressed {
    background-color: #F6DCDC;
}

#deleteFingerprintBtn:disabled {
    background-color: #FAFAFA;
    color: #CCB7B7;
    border-color: #E8E4DE;
}

#collectFingerprintPlaceholderBtn {
    background-color: #FFFFFF;
    color: #2E7D32;
    font-size: 16px;
    border: 1px solid #2E7D32;
    border-radius: 8px;
    padding: 12px 22px;
    min-width: 132px;
}

#collectFingerprintPlaceholderBtn:hover {
    background-color: #E8F5E9;
}

#collectFingerprintPlaceholderBtn:pressed {
    background-color: #C8E6C9;
}

#collectFingerprintPlaceholderBtn:disabled {
    background-color: #FAFAFA;
    color: #B9C2BB;
    border: 1px solid #E8E4DE;
}

#userTable {
    background-color: #FFFFFF;
    border: 1px solid #E8E4DE;
    border-radius: 8px;
    gridline-color: #E8E4DE;
}

#userTable::item {
    padding: 8px;
    border-bottom: 1px solid #E8E4DE;
}

#userTable::item:selected {
    background-color: #E8F5E9;
    color: #2C3E50;
}

#userTable QHeaderView::section {
    background-color: #F5F3EF;
    color: #2C3E50;
    font-weight: bold;
    padding: 10px;
    border: none;
    border-bottom: 1px solid #E8E4DE;
}

/* 表单标题 */
#formTitle {
    color: #2C3E50;
    font-size: 22px;
    font-weight: bold;
    border: none;
    background: transparent;
}

/* 分区标题 - 加粗醒目 */
#sectionTitle1, #basicSectionTitle, #advancedSectionTitle {
    color: #2C3E50;
    font-size: 18px;
    font-weight: bold;
    background: transparent;
    border: none;
    padding: 10px 0;
}

/* 字段标签 - 无边框纯文字 */
#field1Label, #field2Label, #field3Label, #field4Label, 
#field5Label, #field6Label, #field7Label, #field8Label {
    color: #5D6B7A;
    font-size: 17px;
    font-weight: 600;
    background: transparent;
    border: none;
    padding: 0;
}

/* 输入框 */
QLineEdit {
    background-color: #F5F3EF;
    border: 1px solid #E8E4DE;
    border-radius: 10px;
    padding: 16px 18px;
    font-size: 18px;
    color: #2C3E50;
    min-height: 28px;
}

/* 下拉框 */
QComboBox {
    background-color: #F7F6F2;
    border: 1px solid #E3E0D8;
    border-radius: 12px;
    padding: 16px 34px 16px 18px;
    font-size: 18px;
    color: #2C3E50;
    min-width: 140px;
    min-height: 28px;
}

QComboBox:disabled, QComboBox[readOnlyMuted=&quot;true&quot;] {
    background-color: #FAFAFA;
    color: #9AA4AF;
    border: 1px solid #E8E4DE;
}

QComboBox:disabled::drop-down, QComboBox[readOnlyMuted=&quot;true&quot;]::drop-down {
    background: transparent;
}

QComboBox:disabled QAbstractItemView, QComboBox[readOnlyMuted=&quot;true&quot;] QAbstractItemView {
    color: #9AA4AF;
}

QLineEdit:focus, QComboBox:focus {
    border-color: #2E7D32;
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 24px;
    border: none;
    background: transparent;
}

QComboBox::down-arrow {
    image: url(:/branding/chevron_down.svg);
    width: 10px;
    height: 6px;
    margin-right: 8px;
}

QComboBox QAbstractItemView {
    background-color: #FFFFFF;
    color: #1F2937;
    border: 1px solid #DAD7CF;
    border-radius: 12px;
    padding: 4px;
    font-size: 17px;
    selection-background-color: #FFFFFF;
    selection-color: #1F2937;
    outline: 0;
}

QComboBox QAbstractItemView::item {
    min-height: 44px;
    padding: 0 14px;
    color: #1F2937;
    background-color: #FFFFFF;
}

QComboBox QAbstractItemView::item:hover {
    background-color: #FFFFFF;
    color: #1F2937;
}

QComboBox QAbstractItemView::item:selected {
    background-color: #FFFFFF;
    color: #1F2937;
}

/* 刷新按钮 - 点击效果 */
#refreshBtn {
    background-color: #FFFFFF;
    color: #5D6B7A;
    font-size: 15px;
    border: 1px solid #E0E0E0;
    border-radius: 8px;
    padding: 12px 18px;
    min-width: 110px;
}

#refreshBtn:pressed {
    background-color: #BDBDBD;
    border-color: #888888;
    color: #333333;
}

/* 保存按钮 - 点击效果 */
#saveBtn {
    background-color: #2E7D32;
    color: #FFFFFF;
    font-size: 15px;
    border: none;
    border-radius: 8px;
    padding: 12px 20px;
    min-width: 148px;
}

#saveBtn:pressed {
    background-color: #145A14;
}

#serialFixedHintLabel {
    color: #5D6B7A;
    font-size: 16px;
    background-color: #F8FAFB;
    border: 1px solid #E8E4DE;
    border-radius: 10px;
    padding: 14px 18px;
}

#field5Label[readOnlyMuted=&quot;true&quot;], #field6Label[readOnlyMuted=&quot;true&quot;] {
    color: #AAB4AE;
}

#serialFixedHintLabel[readOnlyMuted=&quot;true&quot;] {
    color: #9AA4AF;
    background-color: #FAFAFA;
    border: 1px solid #E8E4DE;
}

/* 分隔线 */
.divider {
    background-color: #E8E4DE;
}
