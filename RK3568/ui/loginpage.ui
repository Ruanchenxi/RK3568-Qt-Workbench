  <property name="styleSheet">
   <string notr="true">
#LoginPage { background-color: #F5F3EF; }
#leftPanel { background-color: #2E7D32; }
#brandIcon { background-color: rgba(255,255,255,0.125); border-radius: 16px; }
#brandTitle { color: #FFFFFF; font-size: 28px; font-weight: normal; }
#brandSubtitle { color: rgba(255,255,255,0.6); font-size: 14px; }
#rightPanel { background-color: #FFFFFF; }
#accountLoginTitle { color: #333333; font-size: 24px; font-weight: bold; }
#usernameEdit, #passwordEdit {
    background-color: #FFFFFF;
    border: 1px solid #DEE2E6;
    border-radius: 8px;
    padding: 12px 16px;
    font-size: 14px;
    color: #333333;
}
#usernameEdit {
    border-right: none;
    border-top-right-radius: 0;
    border-bottom-right-radius: 0;
}
#usernameEdit:focus, #passwordEdit:focus { border: 1px solid #DEE2E6; }
#selectAccountBtn {
    background-color: #F5F7FA;
    color: #2E7D32;
    font-size: 18px;
    font-weight: bold;
    border: 1px solid #DEE2E6;
    border-left: none;
    border-top-right-radius: 8px;
    border-bottom-right-radius: 8px;
    border-top-left-radius: 0;
    border-bottom-left-radius: 0;
    padding: 0;
}
#selectAccountBtn:hover { background-color: #E8F5E9; }
#selectAccountBtn:disabled { color: #9AA4AF; }
#loginBtn {
    background-color: #2E7D32;
    color: #FFFFFF;
    font-size: 16px;
    font-weight: bold;
    border: none;
    border-radius: 8px;
    padding: 14px;
}
#loginBtn:hover { background-color: #1B5E20; }
