  </property>
  <property name="styleSheet">
   <string notr="true">
#LoginPage {
    background-color: #F2F4EF;
}

#leftPanel {
    background-color: #1A2421;
}

#brandDivider {
    background-color: #314038;
}

#logoLabel {
    background: transparent;
}

#companyNameLabel {
    color: #FFFFFF;
    font-size: 18px;
    font-weight: 700;
}

#productSubLabel {
    color: #7E9386;
    font-size: 12px;
}

#productTitleLabel {
    color: #FFFFFF;
    font-size: 32px;
    font-weight: 700;
}

#productPitchLabel {
    color: #A9B5AE;
    font-size: 13px;
}

#dividerLine {
    background-color: #2D3833;
    max-height: 1px;
    border: none;
}

#versionLabel {
    color: #6E7D75;
    font-size: 11px;
}

#rightPanel {
    background-color: #F6F7F4;
}

#loginCard {
    background-color: #FFFFFF;
    border: 1px solid #E2E8E0;
    border-radius: 20px;
}

#loginModeHint {
    color: #6D8A6F;
    font-size: 12px;
    font-weight: 700;
}

#accountLoginTitle {
    color: #19211D;
    font-size: 24px;
    font-weight: 700;
}

#accountLoginDescLabel {
    color: #7E8B83;
    font-size: 13px;
}

#accountFieldLabel, #passwordFieldLabel {
    color: #6D8A6F;
    font-size: 12px;
    font-weight: 700;
}

#usernameEdit, #passwordEdit {
    background-color: #FFFFFF;
    border: 1.5px solid #D9E2D7;
    border-radius: 12px;
    padding: 0 16px;
    font-size: 16px;
    color: #1F2933;
    min-height: 58px;
    max-height: 58px;
}

#usernameEdit:focus, #passwordEdit:focus {
    border-color: #2E7D32;
}

#usernameEdit {
    border-top-right-radius: 0;
    border-bottom-right-radius: 0;
    border-right: none;
}

#selectAccountBtn {
    background-color: #F4F7F1;
    color: #2E7D32;
    border: 1.5px solid #D9E2D7;
    border-left: none;
    border-top-right-radius: 12px;
    border-bottom-right-radius: 12px;
    padding: 0 14px;
    font-size: 14px;
    font-weight: 700;
    min-height: 58px;
    max-height: 58px;
}

#selectAccountBtn:hover {
    background-color: #EAF4EA;
}

#selectAccountBtn[linkedFocus=&quot;true&quot;] {
    border-color: #2E7D32;
    background-color: #EEF6EE;
}

#selectAccountBtn:pressed {
    background-color: #DDEDDD;
}

#selectAccountBtn:disabled {
    background-color: #F6F8F5;
    color: #9AA4AF;
}

#loginBtn {
    background-color: #1F6F2A;
    color: #FFFFFF;
    border: none;
    border-radius: 14px;
    min-height: 60px;
    font-size: 20px;
    font-weight: 700;
    padding: 0 18px;
}

#loginBtn:hover {
    background-color: #175E22;
}

#loginBtn:pressed {
    background-color: #124B1B;
}

#loginBtn:disabled {
    background-color: #A8C2A7;
    color: #F4F7F3;
}

#loginFootHint {
    color: #91A193;
    font-size: 12px;
}
   </string>
