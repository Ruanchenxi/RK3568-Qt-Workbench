  <property name="styleSheet">
   <string notr="true">
/* ========== 登录页面样式 - 方案C ========== */
#LoginPage {
    background-color: #F5F3EF;
}

/* 左侧品牌面板 */
#leftPanel {
    background-color: #2E7D32;
}

#brandIcon {
    background-color: rgba(255, 255, 255, 0.125);
    border-radius: 16px;
}

#brandTitle {
    color: #FFFFFF;
    font-size: 28px;
    font-weight: normal;
}

#brandSubtitle {
    color: rgba(255, 255, 255, 0.6);
    font-size: 14px;
}

/* 右侧登录面板 */
#rightPanel {
    background-color: #FFFFFF;
}

/* 登录标题 */
#loginTitle {
    color: #333333;
    font-size: 24px;
    font-weight: bold;
}

/* 设备卡片通用样式 */
#cardReaderBox, #fingerReaderBox {
    background-color: #F8F9FA;
    border-radius: 12px;
    border: 2px solid #E8F5E9;
}

#fingerReaderBox {
    border-color: #E3F2FD;
}

/* 设备图标容器 */
#cardIconBox {
    background-color: #E8F5E9;
    border-radius: 16px;
}

#fingerIconBox {
    background-color: #E3F2FD;
    border-radius: 16px;
}

/* 设备标签 */
#cardLabel, #fingerLabel {
    color: #333333;
    font-size: 16px;
    font-weight: bold;
}

/* 状态指示器 */
#cardStatusDot, #fingerStatusDot {
    background-color: #22C55E;
    border-radius: 4px;
}

#cardStatusText, #fingerStatusText {
    color: #22C55E;
    font-size: 12px;
}

/* 提示文本 */
#hintLabel {
    color: #999999;
    font-size: 14px;
}

/* 分割线 */
#dividerLine1, #dividerLine2 {
    background-color: #E0E0E0;
}

#dividerText {
    color: #999999;
    font-size: 12px;
}

/* 账号密码登录按钮 */
#accountLoginBtn {
    background-color: #2E7D32;
    color: #FFFFFF;
    font-size: 14px;
    font-weight: bold;
    border: none;
    border-radius: 8px;
    padding: 14px 32px;
}

#accountLoginBtn:hover {
    background-color: #1B5E20;
}

#accountLoginBtn:pressed {
    background-color: #145214;
}

/* ========== 账号密码登录区域 ========== */
#usernameEdit, #passwordEdit {
    background-color: #FFFFFF;
    border: 1px solid #E0E0E0;
    border-radius: 8px;
    padding: 12px 16px;
    font-size: 14px;
    color: #333333;
}

#usernameEdit:focus, #passwordEdit:focus {
    border-color: #2E7D32;
}

#selectAccountBtn {
    background-color: #F5F7FA;
    color: #2E7D32;
    font-size: 14px;
    font-weight: bold;
    border: 1px solid #D0D7DE;
    border-radius: 8px;
    padding: 12px 18px;
}

#selectAccountBtn:hover {
    background-color: #E8F5E9;
}

#selectAccountBtn:disabled {
    color: #9AA4AF;
}

#loginBtn {
    background-color: #2E7D32;
    color: #FFFFFF;
    font-size: 16px;
    font-weight: bold;
    border: none;
    border-radius: 8px;
    padding: 14px;
}

#loginBtn:hover {
    background-color: #1B5E20;
}

#backBtn {
    background-color: transparent;
    color: #2E7D32;
    font-size: 14px;
    border: 1px solid #2E7D32;
    border-radius: 8px;
    padding: 10px 20px;
}

#backBtn:hover {
    background-color: #E8F5E9;
}
   </string>
