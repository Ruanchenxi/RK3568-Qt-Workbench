  <property name="styleSheet">
   <string notr="true">
/* ========== 全局样式 ========== */
QMainWindow {
    background-color: #F5F3EF;
}

/* ========== 顶部导航栏样式 ========== */
#headerWidget {
    background-color: #FFFFFF;
    border-bottom: 1px solid #E8E4DE;
}

/* Logo区域标题 */
#systemTitle {
    color: #233229;
    font-size: 18px;
    font-weight: 700;
}

/* 导航按钮通用样式 */
#btnWorkbench, #btnKeys, #btnSystem, #btnService, #btnKeyboard {
    background-color: transparent;
    color: #5D6B7A;
    font-size: 14px;
    border: 1px solid transparent;
    border-radius: 6px;
    padding: 10px 20px;
}

#btnWorkbench:hover, #btnKeys:hover, #btnSystem:hover, #btnService:hover, #btnKeyboard:hover {
    background-color: #E8E4DE;
}

#btnWorkbench:checked, #btnKeys:checked, #btnSystem:checked, #btnService:checked, #btnKeyboard:checked {
    background-color: #2E7D32;
    color: #FFFFFF;
}

#btnWorkbench[restricted=&quot;true&quot;], #btnKeys[restricted=&quot;true&quot;] {
    color: #97A59C;
    background-color: transparent;
    border: 1px solid #E3EAE4;
}

#btnWorkbench[restricted=&quot;true&quot;]:hover, #btnKeys[restricted=&quot;true&quot;]:hover {
    background-color: #F3F6F2;
    color: #6E7D75;
}

/* 用户信息 */
#userNameLabel {
    color: #2C3E50;
    font-size: 14px;
}

/* 退出按钮 */
#logoutBtn {
    background-color: transparent;
    color: #5D6B7A;
    font-size: 13px;
    border: 1px solid #E0E0E0;
    border-radius: 6px;
    padding: 8px 16px;
}

#logoutBtn:hover {
    background-color: #F5F5F5;
}

/* ========== 底部状态栏样式 ========== */
#footerWidget {
    background-color: #FFFFFF;
    border-top: 1px solid #D8D2C7;
    min-height: 50px;
}

#companyLabel {
    color: #9E9E9E;
    font-size: 12px;
}

#timeLabel {
    color: #5D6B7A;
    font-size: 12px;
}

#userInfoLabel, #roleLabel {
    color: #5D6B7A;
    font-size: 12px;
}

#cardStatusLabel, #fingerStatusLabel {
    color: #5D6B7A;
    font-size: 12px;
}

/* ========== 内容区域样式 ========== */
#contentStackedWidget {
    background-color: transparent;
}

QFrame#loginShellCard,
QFrame#workbenchShellCard,
QFrame#keyManageShellCard,
QFrame#systemShellCard,
QFrame#logShellCard,
QFrame#keyboardShellCard {
    background-color: #FFFFFF;
    border: 1px solid #E8E4DE;
    border-radius: 12px;
    min-height: 160px;
}

QFrame#loginShellDock,
QFrame#workbenchShellDock,
QFrame#keyManageShellDock,
QFrame#systemShellDock,
QFrame#logShellDock,
QFrame#keyboardShellDock {
    background-color: #FAF8F4;
    border: 1px dashed #D8D2C7;
    border-radius: 10px;
    min-height: 96px;
}

QFrame#loginShellPlaceholder,
QFrame#loginShellAuthCard,
QFrame#loginShellKeyboardCard,
QFrame#workbenchShellSummaryCard,
QFrame#workbenchShellDetailCard,
QFrame#keyManageShellInfoCard,
QFrame#keyManageShellActionCard,
QFrame#systemShellParamsCard,
QFrame#systemShellLinkCard,
QFrame#logShellListCard,
QFrame#logShellDetailCard {
    background-color: #FFFFFF;
    border: 1px solid #ECE6DC;
    border-radius: 10px;
    min-width: 220px;
    min-height: 84px;
}
   </string>
